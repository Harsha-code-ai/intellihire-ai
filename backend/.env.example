# ─── IntelliHire Pro — Environment Variables ──────────────────────────────────
# Copy this file to .env for local development.
# On Render: set these in the "Environment" tab of your service.
# On Vercel (frontend): set VITE_API_URL.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI features (resume analysis, question generation, evaluation).
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# Model to use — gpt-4o-mini is fast and cost-effective
OPENAI_MODEL=gpt-4o-mini

# Timeout for each OpenAI request in seconds (default 30)
OPENAI_TIMEOUT=30

# ── Database ──────────────────────────────────────────────────────────────────
# STRONGLY recommended for Render: use a PostgreSQL database.
# Free PostgreSQL on Render: https://render.com/docs/databases
#
# PostgreSQL (production):
DATABASE_URL=postgresql://user:password@host:5432/intellihire
#
# SQLite (local dev only — data is lost on Render redeploys!):
# DATABASE_URL=sqlite:///./intellihire.db
#
# Custom SQLite path (e.g. if you attach a Render Disk):
# SQLITE_PATH=/data/intellihire.db

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-string

# Token expiry in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────────
# Extra frontend origins allowed (comma-separated).
# Your Vercel URL is already included in main.py defaults.
# Only needed if you have additional frontend deployments:
# ALLOWED_ORIGINS=https://my-other-app.vercel.app,https://staging.myapp.com

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set this in your Vercel project settings → Environment Variables
# VITE_API_URL=https://intellihire-ai-2-hr31.onrender.com
