# ─── IntelliHire Pro — Backend Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.

# OpenAI API key (required for AI features)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# OpenAI model to use (default: gpt-4o-mini — fast and cost-effective)
OPENAI_MODEL=gpt-4o-mini

# JWT secret key — change this to a long random string in production!
SECRET_KEY=intellihire-change-this-secret-in-production

# Token expiry in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database URL
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./intellihire.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/intellihire
